---
import { Home, Briefcase, Mail } from "@lucide/astro";

const navItems = [
    {
        label: "Home",
        href: "/",
        icon: Home,
    },
    {
        label: "Projects",
        href: "/projects",
        icon: Briefcase,
    },
    {
        label: "Contact",
        href: "/#contact",
        icon: Mail,
    },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
    if (href === "/") return currentPath === "/";
    if (href.startsWith("/#")) return false;
    return currentPath.startsWith(href);
}
---

<!-- Desktop Navbar: top center pill -->
<nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50 hidden md:flex">
    <div class="nav-pill flex items-center gap-0.5 px-2 py-2 rounded-2xl">
        {
            navItems.map((item) => (
                <a
                    href={item.href}
                    class={`nav-link flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200 ${
                        isActive(item.href)
                            ? "nav-active"
                            : "text-gray-400 hover:text-white hover:bg-white/5"
                    }`}
                >
                    <item.icon class="w-[18px] h-[18px] stroke-[1.7px] shrink-0" />
                    <span>{item.label}</span>
                </a>
            ))
        }
    </div>
</nav>

<!-- Mobile Navbar: bottom fixed pill -->
<nav class="fixed bottom-5 left-1/2 -translate-x-1/2 z-50 flex md:hidden">
    <div class="nav-pill flex items-center gap-0.5 px-2 py-2 rounded-2xl">
        {
            navItems.map((item) => (
                <a
                    href={item.href}
                    aria-label={item.label}
                    class={`nav-link flex flex-col items-center gap-1 px-3 py-2 rounded-xl transition-all duration-200 ${
                        isActive(item.href)
                            ? "nav-active"
                            : "text-gray-500 hover:text-gray-300 hover:bg-white/5"
                    }`}
                >
                    <item.icon class="w-[18px] h-[18px] stroke-[1.7px] shrink-0" />
                    <span class="text-[9px] font-bold tracking-wider uppercase">
                        {item.label}
                    </span>
                </a>
            ))
        }
    </div>
</nav>
