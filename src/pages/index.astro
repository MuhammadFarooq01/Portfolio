---
import Main from "../layouts/main.astro";
import { Image } from "astro:assets";
import {
	Github,
	Twitter,
	Linkedin,
	Mail,
	ChevronDown,
	ArrowRight,
} from "@lucide/astro";
import { projects } from "../data/projects";
---

<Main>
	<div class="h-20 md:h-24 shrink-0"></div>
	<div class="page-wrapper w-full px-4 sm:px-6 md:px-8 py-8 md:py-16">
		<div
			class="flex flex-col lg:flex-row gap-8 lg:gap-16 items-start w-full max-w-6xl mx-auto"
		>
			<!-- LEFT: Profile Card (Sticky on desktop) -->
			<div
				class="lg:sticky lg:top-24 lg:self-start shrink-0 w-full lg:w-auto"
			>
				<div
					class="noise-card rounded-3xl py-3 flex flex-col overflow-hidden lg:w-90 lg:max-h-170"
				>
					<!-- Horizontal on mobile, vertical on desktop -->
					<div
						class="flex flex-row lg:flex-col items-center lg:items-center px-6 lg:px-10 pt-5 flex-1 gap-6 lg:gap-0"
					>
						<Image
							src="/pfp.avif"
							alt="Profile"
							width={300}
							height={300}
							class="h-24 w-24 lg:h-auto lg:w-full rounded-2xl object-cover flex-shrink-0"
						/>
						<div
							class="flex flex-col lg:items-center gap-3 lg:gap-5 lg:px-7 lg:py-6 w-full"
						>
							<div
								class="flex flex-col lg:items-center lg:text-center gap-1"
							>
								<h1
									class="text-xl lg:text-2xl font-bold text-white tracking-tight"
								>
									Muhammad Farooq
								</h1>
								<p class="text-gray-300 font-semibold text-sm">
									Full Stack Developer
								</p>
								<p class="text-gray-400 font-medium text-sm">
									Islamabad, Pakistan
								</p>
							</div>
							<!-- Social Icons -->
							<div
								class="flex items-center gap-4 lg:gap-6 text-gray-400"
							>
								<a
									href="#"
									class="hover:text-white transition-colors duration-200"
								>
									<Twitter class="w-5 h-5" />
								</a>
								<a
									href="#"
									class="hover:text-white transition-colors duration-200"
								>
									<Github class="w-5 h-5" />
								</a>
								<a
									href="#"
									class="hover:text-white transition-colors duration-200"
								>
									<Linkedin class="w-5 h-5" />
								</a>
								<a
									href="mailto:hello@muhammadfarooq.dev"
									class="hover:text-white transition-colors duration-200"
								>
									<Mail class="w-5 h-5" />
								</a>
							</div>
						</div>
					</div>
					<!-- CTA -->
					<div
						class="flex items-center justify-center px-5 pb-5 mt-4 lg:mt-0"
					>
						<a
							href="mailto:hello@muhammadfarooq.dev"
							class="hero-cta-btn max-w-[200px] w-full font-semibold text-white text-sm py-3.5 rounded-xl transition-all duration-200 hover:opacity-90 active:scale-95 text-center"
						>
							Let's Talk
						</a>
					</div>
				</div>
			</div>

			<!-- RIGHT: Scrollable Content -->
			<div class="flex flex-col flex-1 min-w-0">
				<!-- Hero Content -->
				<div class="flex flex-col gap-8 md:gap-10 pt-4 md:pt-12">
					<div class="flex flex-col gap-4 md:gap-6">
						<h2
							class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight tracking-tight"
						>
							Transforming Your<br />
							Ideas into <span class="hero-reality">Reality</span>
						</h2>
						<p
							class="text-gray-400 leading-relaxed text-[15px] max-w-[420px]"
						>
							Passionate about creating intuitive and engaging
							user experiences. Specialize in transforming ideas
							into beautifully crafted products.
						</p>
					</div>

					<!-- Stats -->
					<div class="flex gap-8 md:gap-16">
						<div>
							<p
								class="text-[clamp(2.5rem,4.5vw,4.5rem)] font-extrabold text-white leading-none tracking-tight"
							>
								+2
							</p>
							<p
								class="text-[0.65rem] text-gray-400 uppercase tracking-[0.15em] mt-2 leading-tight"
							>
								Years of<br />Experience
							</p>
						</div>
						<div>
							<p
								class="text-[clamp(2.5rem,4.5vw,4.5rem)] font-extrabold text-white leading-none tracking-tight"
							>
								+10
							</p>
							<p
								class="text-[0.65rem] text-gray-400 uppercase tracking-[0.15em] mt-2 leading-tight"
							>
								Projects<br />Completed
							</p>
						</div>
						<div>
							<p
								class="text-[clamp(2.5rem,4.5vw,4.5rem)] font-extrabold text-white leading-none tracking-tight"
							>
								+6
							</p>
							<p
								class="text-[0.65rem] text-gray-400 uppercase tracking-[0.15em] mt-2 leading-tight"
							>
								Worldwide<br />Clients
							</p>
						</div>
					</div>

					<!-- Buttons -->
					<div class="flex items-center gap-6 md:gap-8 flex-wrap">
						<a
							href="mailto:hello@muhammadfarooq.dev"
							class="hero-cta-btn font-semibold text-white text-sm px-8 md:px-9 py-4 rounded-xl transition-all duration-200 hover:opacity-90 active:scale-95"
						>
							Let's Talk
						</a>
						<a
							href="/projects"
							class="flex items-center gap-2 text-white font-medium text-sm hover:opacity-70 transition-opacity duration-200"
						>
							My Work <span class="ml-1 text-base">→</span>
						</a>
					</div>
				</div>

				<!-- TECH STACK SECTION -->
				<div class="py-12 md:py-16 mt-6 scroll-reveal" id="stack">
					<p class="project-section-label">Tech Stack</p>
					<div class="grid grid-cols-4 sm:grid-cols-4 gap-2 md:gap-3">
						{
							[
								{
									name: "MongoDB",
									color: "#47A248",
									svg: `<path d="M15.9 2C15.9 2 9.3 10.1 9.3 17.3c0 3.6 2.9 6.6 6.6 6.6s6.6-3 6.6-6.6C22.5 10.1 15.9 2 15.9 2z" fill="#47A248"/><path d="M15.9 2v21.9" stroke="#B8C4C2" stroke-width="1.2" stroke-linecap="round"/><path d="M15.9 23.9c0 0 0 4.5 0 6.1" stroke="#47A248" stroke-width="1.5" stroke-linecap="round"/>`,
								},
								{
									name: "Express",
									color: "#9ca3af",
									svg: `<text x="2" y="22" font-family="monospace" font-size="11" font-weight="bold" fill="#9ca3af">exp</text><path d="M2 26h28M2 6h28" stroke="#4b5563" stroke-width="1" stroke-linecap="round"/>`,
								},
								{
									name: "React",
									color: "#61DAFB",
									svg: `<circle cx="16" cy="16" r="2.5" fill="#61DAFB"/><ellipse cx="16" cy="16" rx="12" ry="4.5" stroke="#61DAFB" stroke-width="1.5" fill="none"/><ellipse cx="16" cy="16" rx="12" ry="4.5" stroke="#61DAFB" stroke-width="1.5" fill="none" transform="rotate(60 16 16)"/><ellipse cx="16" cy="16" rx="12" ry="4.5" stroke="#61DAFB" stroke-width="1.5" fill="none" transform="rotate(120 16 16)"/>`,
								},
								{
									name: "Next.js",
									color: "#ffffff",
									svg: `<circle cx="16" cy="16" r="13" fill="#000" stroke="#fff" stroke-width="1.2"/><path d="M10.5 21V11h2l7 8.5V11H21v10h-2L12 12.5V21h-1.5z" fill="white"/>`,
								},
								{
									name: "Node.js",
									color: "#339933",
									svg: `<path d="M16 3L4 9.5v13L16 29l12-6.5v-13L16 3z" fill="#339933" opacity="0.15"/><path d="M16 3L4 9.5v13L16 29l12-6.5v-13L16 3z" stroke="#339933" stroke-width="1.5" fill="none"/><text x="10" y="20" font-family="monospace" font-size="9" font-weight="bold" fill="#339933">JS</text>`,
								},
								{
									name: "TypeScript",
									color: "#3178C6",
									svg: `<rect x="3" y="3" width="26" height="26" rx="3" fill="#3178C6"/><text x="6" y="23" font-family="monospace" font-size="13" font-weight="bold" fill="white">TS</text>`,
								},
								{
									name: "Astro",
									color: "#FF5D01",
									svg: `<path d="M16 4C16 4 11 14 11 19c0 2.76 2.24 5 5 5s5-2.24 5-5c0-5-5-15-5-15z" fill="#FF5D01"/><path d="M10 22c-2-1-4-4-4-7 0-2 1-5 3-7" stroke="#FF5D01" stroke-width="1.3" stroke-linecap="round" fill="none" opacity="0.5"/><path d="M22 22c2-1 4-4 4-7 0-2-1-5-3-7" stroke="#FF5D01" stroke-width="1.3" stroke-linecap="round" fill="none" opacity="0.5"/>`,
								},
								{
									name: "Tailwind",
									color: "#06B6D4",
									svg: `<path d="M9 13c.7-2.8 2.4-4.2 5-4.2 3.8 0 4.3 2.8 6.2 3.3 1.3.3 2.4-.2 3.4-1.5C23 13.4 21.3 15 18.7 15c-3.8 0-4.3-2.8-6.2-3.3C11.2 11.4 10 12 9 13zm-3.5 4.2C6.2 14.4 7.9 13 10.5 13c3.8 0 4.3 2.8 6.2 3.3 1.3.3 2.4-.2 3.4-1.5-.6 2.8-2.4 4.2-5 4.2-3.8 0-4.3-2.8-6.2-3.3-1.3-.3-2.4.2-3.4 1.5z" fill="#06B6D4"/>`,
								},
							].map((tech) => (
								<div class="tech-pill noise-card rounded-2xl px-2 md:px-4 py-3 md:py-4 flex flex-col items-center gap-2 group">
									<svg
										class="tech-icon"
										width="28"
										height="28"
										viewBox="0 0 32 32"
										fill="none"
										set:html={tech.svg}
									/>
									<span class="tech-label text-[10px] md:text-[11px] font-semibold text-gray-400 group-hover:text-white transition-colors">
										{tech.name}
									</span>
								</div>
							))
						}
					</div>
				</div>

				<!-- Recent Projects Section -->
				<div class="py-12 md:py-16 scroll-reveal" id="projects">
					<div
						class="flex items-end justify-between mb-8 md:mb-10 gap-4"
					>
						<div>
							<h2
								class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight tracking-tight"
							>
								Recent Projects<br />and <span
									class="hero-reality">Achievements</span
								>
							</h2>
							<p
								class="text-gray-400 mt-3 md:mt-4 text-sm font-medium"
							>
								Some of my best work and side projects.
							</p>
						</div>
						<a
							href="/projects"
							class="text-accent font-semibold hover:underline transition-all whitespace-nowrap text-sm"
						>
							View All →
						</a>
					</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-5">
						{
							projects.slice(0, 4).map((project) => (
								<a
									href={`/projects/${project.slug}`}
									class="project-card noise-card rounded-2xl overflow-hidden group block"
								>
									<div class="project-card-img">
										<img
											src={project.coverImage}
											alt={project.title}
											class="w-full h-44 md:h-52 object-cover"
											loading="lazy"
											transition:name={`project-image-${project.slug}`}
										/>
									</div>
									<div class="p-4 md:p-5">
										<h3
											class="text-lg font-bold text-accent"
											transition:name={`project-title-${project.slug}`}
										>
											{project.title}
										</h3>
										<p class="text-gray-400 text-sm mt-1">
											{project.tagline}
										</p>
									</div>
								</a>
							))
						}
					</div>
				</div>

				<!-- FAQ SECTION -->
				<div class="py-12 md:py-16 scroll-reveal" id="faq">
					<div class="mb-8 md:mb-10">
						<h2
							class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight tracking-tight"
						>
							Frequently<br />
							Asked <span class="hero-reality">Questions</span>
						</h2>
					</div>
					<div class="flex flex-col gap-2" id="faq-list">
						{
							[
								{
									q: "What services do you offer?",
									a: "I offer full-stack web development, UI/UX design, Framer templates, and consulting. From landing pages to complex SaaS applications — if it lives on the web, I can build it.",
								},
								{
									q: "What is your design process?",
									a: "I start with understanding your goals and audience, then move into wireframes and a design system. Once we align on the direction, I build the final product with clean, maintainable code.",
								},
								{
									q: "How do you handle project timelines?",
									a: "Every project gets a clear scope and timeline upfront. I use weekly check-ins to keep you updated and deliver in milestones so you can review progress along the way.",
								},
								{
									q: "Can you work with existing teams?",
									a: "Absolutely. I'm comfortable jumping into an existing codebase, adapting to your team's workflow, and contributing to ongoing projects — whether as a contractor or collaborator.",
								},
								{
									q: "What tools do you use?",
									a: "My main stack is React, Next.js, Astro, Node.js, TypeScript, and Tailwind CSS. For design I use Figma and Framer. I adapt to project needs though — tools should serve the work, not define it.",
								},
							].map((item, i) => (
								<div
									class="faq-item noise-card rounded-2xl overflow-hidden"
									data-index={i}
								>
									<button
										class="faq-trigger w-full flex items-center justify-between px-5 md:px-6 py-4 md:py-5 text-left group cursor-pointer"
										aria-expanded="false"
									>
										<span class="text-sm md:text-[15px] font-semibold text-gray-200 group-hover:text-white transition-colors">
											{item.q}
										</span>
										<ChevronDown
											class="faq-chevron shrink-0 ml-4 text-gray-500 transition-all duration-300 w-[18px] h-[18px]"
											stroke-width="2"
										/>
									</button>
									<div class="faq-body">
										<p class="text-gray-400 text-sm leading-relaxed px-5 md:px-6 pb-4 md:pb-5">
											{item.a}
										</p>
									</div>
								</div>
							))
						}
					</div>
				</div>

				<!-- LET'S COLLABORATE SECTION -->
				<div class="py-8 pb-24 md:pb-24 scroll-reveal" id="contact">
					<a
						href="mailto:hello@muhammadfarooq.dev"
						class="collab-card group noise-card rounded-2xl p-7 md:p-10 flex items-start justify-between gap-6 transition-all duration-300 block"
					>
						<div class="flex flex-col gap-3 max-w-sm">
							<h2
								class="text-3xl md:text-4xl font-extrabold text-white leading-tight tracking-tight"
							>
								Let's<br /><span class="hero-reality"
									>collaborate</span
								>
							</h2>
							<p class="text-gray-400 text-sm leading-relaxed">
								Unlock the potential of your product with expert
								design and development services. Let's create
								user-centered solutions that delight your users.
							</p>
						</div>
						<div
							class="collab-arrow shrink-0 w-12 h-12 rounded-full flex items-center justify-center transition-all duration-300 mt-1"
						>
							<ArrowRight class="w-5 h-5" stroke-width="2.5" />
						</div>
					</a>
				</div>
			</div>
		</div>
	</div>
</Main>

<script>
	// FAQ accordion
	document.addEventListener("astro:page-load", () => {
		const triggers = document.querySelectorAll(".faq-trigger");
		triggers.forEach((trigger) => {
			trigger.addEventListener("click", () => {
				const item = trigger.closest(".faq-item") as HTMLElement;
				const body = item.querySelector(".faq-body") as HTMLElement;
				const isOpen = item.classList.contains("open");

				document.querySelectorAll(".faq-item").forEach((el) => {
					el.classList.remove("open");
					const b = el.querySelector(".faq-body") as HTMLElement;
					if (b) b.style.maxHeight = "0";
					const btn = el.querySelector(".faq-trigger");
					if (btn) btn.setAttribute("aria-expanded", "false");
				});

				if (!isOpen) {
					item.classList.add("open");
					body.style.maxHeight = body.scrollHeight + "px";
					trigger.setAttribute("aria-expanded", "true");
				}
			});
		});
	});
</script>
