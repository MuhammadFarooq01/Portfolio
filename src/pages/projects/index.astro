---
import Main from "../../layouts/main.astro";
import { projects } from "../../data/projects";
import { ArrowRight } from "@lucide/astro";
---

<Main title="My Work — Portfolio">
    <div
        class="pt-24 md:pt-32 pb-16 px-4 sm:px-6 md:px-8 max-w-5xl mx-auto w-full"
    >
        <!-- Header -->
        <header class="mb-12 md:mb-16 scroll-reveal">
            <h1
                class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-900 leading-tight tracking-tight mb-4 md:mb-6"
            >
                Selected <span class="hero-reality">Works</span>
            </h1>
            <p
                class="text-xl md:text-2xl text-gray-500 font-medium max-w-2xl leading-relaxed"
            >
                A collection of my recent projects, side-hustles, and
                open-source contributions.
            </p>
        </header>

        <!-- Projects Grid -->
        <div
            class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8 pb-12 md:pb-24"
        >
            {
                projects.map((project) => (
                    <a
                        href={`/projects/${project.slug}`}
                        class="project-card noise-card rounded-3xl overflow-hidden group block scroll-reveal"
                    >
                        <div class="project-card-img relative">
                            <img
                                src={project.coverImage}
                                alt={project.title}
                                class="w-full h-64 md:h-72 object-cover"
                                loading="lazy"
                                transition:name={`project-image-${project.slug}`}
                            />
                            <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent flex items-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                <span class="inline-flex items-center gap-2 text-gray-900 font-medium text-sm bg-accent/90 px-4 py-2 rounded-full backdrop-blur-sm">
                                    View Case Study{" "}
                                    <ArrowRight class="w-4 h-4" />
                                </span>
                            </div>
                        </div>
                        <div class="p-6 md:p-8">
                            <div class="flex items-start justify-between gap-4 mb-2">
                                <h3
                                    class="text-2xl font-bold text-gray-900 group-hover:text-accent transition-colors"
                                    transition:name={`project-title-${project.slug}`}
                                >
                                    {project.title}
                                </h3>
                                <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-gray-100 text-gray-600 border border-gray-200 shrink-0">
                                    {project.year}
                                </span>
                            </div>
                            <p class="text-gray-500 text-sm md:text-[15px] leading-relaxed mb-6">
                                {project.tagline}
                            </p>

                            <div class="flex flex-wrap gap-2">
                                {project.tags.map((tag) => (
                                    <span class="text-[10px] uppercase tracking-wider font-bold text-gray-500 bg-gray-100 px-2 py-1 rounded-md">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</Main>
