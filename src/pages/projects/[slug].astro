---
import Main from "../../layouts/main.astro";
import { projects } from "../../data/projects";
import { ArrowLeft, ExternalLink, Github, Check } from "@lucide/astro";
import { marked } from "marked";

export async function getStaticPaths() {
    return projects.map((project) => {
        return {
            params: { slug: project.slug },
            props: { project },
        };
    });
}

const { project } = Astro.props;

// Convert markdown description to HTML safely
const parsedDescription = marked.parse(project.longDescription) as string;
---

<Main title={`${project.title} - Project Details`}>
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />

    <div
        class="pt-24 md:pt-32 pb-16 px-4 sm:px-6 md:px-8 max-w-5xl mx-auto w-full"
    >
        <a
            href="/"
            class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white dark:text-white transition-colors mb-8 md:mb-12"
        >
            <ArrowLeft class="w-4 h-4" /> Back to home
        </a>

        <!-- Hero Section (Split Layout) -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-16 md:mb-24">
            
            <!-- Left: Text & CTA -->
            <header class="flex flex-col gap-6 md:gap-8 scroll-reveal pt-4 md:pt-0">
                <div>
                    <h1
                        class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-900 dark:text-white leading-tight tracking-tight mb-4 md:mb-6"
                        transition:name={`project-title-${project.slug}`}
                    >
                        {project.title}
                    </h1>
                    <p
                        class="text-xl md:text-2xl text-gray-500 dark:text-gray-400 font-medium leading-relaxed"
                    >
                        {project.tagline}
                    </p>
                </div>
                
                <!-- Links -->
                <div class="flex flex-wrap items-center gap-4">
                    {project.liveUrl && (
                        <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="hero-cta-btn font-semibold text-gray-900 dark:text-white text-sm px-6 py-3.5 rounded-xl transition-all duration-200 hover:opacity-90 active:scale-95 flex items-center gap-2">
                            <ExternalLink class="w-4 h-4" /> Live Preview
                        </a>
                    )}
                    {project.githubUrl && (
                        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="bg-gray-100 dark:bg-white/10 border border-gray-200 dark:border-white/10 bg-gray-200 font-semibold text-gray-900 dark:text-white text-sm px-6 py-3.5 rounded-xl transition-all duration-200 active:scale-95 flex items-center gap-2">
                            <Github class="w-4 h-4" /> Source Code
                        </a>
                    )}
                </div>
            </header>

            <!-- Right: Mockup -->
            <div class="w-full flex justify-center scroll-reveal">
                {project.mockupType === "mobile" ? (
                    <!-- iOS Mockup (with notch and buttons) -->
                    <div class="relative mx-auto border-gray-900 bg-gray-900 border-14 rounded-[3rem] h-[600px] w-[300px] shadow-2xl overflow-hidden noise-card shrink-0">
                        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[120px] h-[25px] bg-gray-900 rounded-b-2xl z-20"></div>
                        <div class="h-[32px] w-[3px] bg-gray-800 absolute -left-[17px] top-[72px] rounded-s-lg"></div>
                        <div class="h-[46px] w-[3px] bg-gray-800 absolute -left-[17px] top-[124px] rounded-s-lg"></div>
                        <div class="h-[46px] w-[3px] bg-gray-800 absolute -left-[17px] top-[178px] rounded-s-lg"></div>
                        <div class="h-[64px] w-[3px] bg-gray-800 absolute -right-[17px] top-[142px] rounded-e-lg"></div>
                        <div class="rounded-[2.25rem] overflow-hidden w-[272px] h-[572px] bg-white dark:bg-gray-800 relative z-10 flex items-center justify-center">
                            {project.videoUrl ? (
                                <div class="plyr__video-embed w-full h-full bg-black flex" id="player">
                                    <iframe src={`${project.videoUrl}?origin=https://plyr.io&amp;iv_load_policy=3&amp;modestbranding=1&amp;playsinline=1&amp;showinfo=0&amp;rel=0&amp;enablejsapi=1`} allowfullscreen allowtransparency allow="autoplay"></iframe>
                                </div>
                            ) : (
                                <img src={project.coverImage} alt={`${project.title} cover`} class="w-full h-full object-cover" transition:name={`project-image-${project.slug}`} />
                            )}
                        </div>
                    </div>
                ) : project.mockupType === "desktop" ? (
                    <!-- macOS Mockup -->
                    <div class="relative mx-auto border-gray-800/80 bg-gray-800/80 border p-2 pt-0 rounded-2xl shadow-2xl w-full noise-card backdrop-blur-md">
                        <div class="w-full h-8 flex items-center px-3 gap-2">
                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                        </div>
                        <div class="rounded-xl overflow-hidden aspect-video bg-black relative z-10 border border-gray-900/50">
                            {project.videoUrl ? (
                                <div class="plyr__video-embed w-full h-full bg-black flex" id="player">
                                    <iframe src={`${project.videoUrl}?origin=https://plyr.io&amp;iv_load_policy=3&amp;modestbranding=1&amp;playsinline=1&amp;showinfo=0&amp;rel=0&amp;enablejsapi=1`} allowfullscreen allowtransparency allow="autoplay"></iframe>
                                </div>
                            ) : (
                                <img src={project.coverImage} alt={`${project.title} cover`} class="w-full h-full object-cover" transition:name={`project-image-${project.slug}`} />
                            )}
                        </div>
                    </div>
                ) : (
                    <!-- Default fallback -->
                    <div class="rounded-3xl overflow-hidden noise-card p-2 md:p-3 w-full shadow-2xl">
                        {project.videoUrl ? (
                            <div class="plyr__video-embed flex w-full aspect-video rounded-2xl overflow-hidden bg-black relative" id="player">
                                <iframe src={`${project.videoUrl}?origin=https://plyr.io&amp;iv_load_policy=3&amp;modestbranding=1&amp;playsinline=1&amp;showinfo=0&amp;rel=0&amp;enablejsapi=1`} allowfullscreen allowtransparency allow="autoplay"></iframe>
                            </div>
                        ) : (
                            <img src={project.coverImage} alt={`${project.title} cover`} class="w-full aspect-video object-cover rounded-2xl" transition:name={`project-image-${project.slug}`} />
                        )}
                    </div>
                )}
            </div>
        </div>

        <!-- Project Details Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">
            <!-- Left Content: Description & Images -->
            <div class="lg:col-span-2 flex flex-col gap-12 md:gap-16">
                <!-- About -->
                <section class="scroll-reveal">
                    <!-- Clean, editorial header -->
                    <div class="mb-10 lg:mb-12">
                        <div class="flex items-center gap-4 mb-6">
                            <h2 class="text-3xl sm:text-4xl md:text-5xl font-playfair font-bold text-gray-900 dark:text-white tracking-tight">
                                About the Project
                            </h2>
                            <div class="h-px flex-1 bg-gray-200 mt-2"></div>
                        </div>
                    </div>

                    <!-- Content -->
                    <div
                        class="prose prose-invert prose-lg md:prose-xl max-w-none prose-headings:font-playfair prose-headings:font-bold prose-headings:text-gray-900 dark:text-white prose-headings:mt-8 prose-headings:mb-4 prose-p:leading-relaxed prose-p:text-gray-600 dark:text-gray-300/90 prose-a:text-accent hover:prose-a:text-accent-light prose-strong:text-gray-900 dark:text-white prose-ul:text-gray-600 dark:text-gray-300/90 prose-li:marker:text-gray-500 dark:text-gray-400"
                    >
                        <Fragment set:html={parsedDescription} />
                    </div>
                </section>

                <!-- Highlights -->
                <section class="scroll-reveal">
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
                        Key Highlights
                    </h2>
                    <ul class="flex flex-col gap-4">
                        {
                            project.highlights.map((highlight) => (
                                <li class="flex items-start gap-3 text-gray-600 dark:text-gray-300">
                                    <Check class="w-6 h-6 text-accent shrink-0 mt-0.5" />
                                    <span class="leading-relaxed">
                                        {highlight}
                                    </span>
                                </li>
                            ))
                        }
                    </ul>
                </section>

                <!-- Gallery -->
                {
                    project.images && project.images.length > 0 && (
                        <section class="scroll-reveal">
                            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 md:mb-8">
                                Gallery
                            </h2>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
                                {project.images.map((img) => (
                                    <a
                                        data-fslightbox="gallery"
                                        href={img}
                                        class="group rounded-2xl overflow-hidden block noise-card p-1 transition-transform duration-300 hover:scale-[1.02]"
                                    >
                                        <div class="relative w-full aspect-video rounded-xl overflow-hidden bg-surface-light">
                                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center z-10 pointer-events-none">
                                                <span class="text-gray-900 dark:text-white font-medium text-sm bg-black/60 px-4 py-2 rounded-full backdrop-blur-sm">
                                                    View
                                                </span>
                                            </div>
                                            <img
                                                src={img}
                                                alt={`${project.title} gallery shot`}
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                                loading="lazy"
                                            />
                                        </div>
                                    </a>
                                ))}
                            </div>
                        </section>
                    )
                }
            </div>

            <!-- Right Content: Meta Info -->
            <div class="lg:col-span-1">
                <div
                    class="sticky top-32 noise-card rounded-3xl p-6 md:p-8 flex flex-col gap-8 scroll-reveal"
                >
                    <!-- Meta -->
                    <div class="flex flex-col gap-6">
                        <div>
                            <p
                                class="text-gray-500 dark:text-gray-400 font-semibold text-xs tracking-wider uppercase mb-2"
                            >
                                Role
                            </p>
                            <p class="text-gray-900 dark:text-gray-200 font-medium">
                                {project.role}
                            </p>
                        </div>
                        <div>
                            <p
                                class="text-gray-500 dark:text-gray-400 font-semibold text-xs tracking-wider uppercase mb-2"
                            >
                                Year
                            </p>
                            <p class="text-gray-900 dark:text-gray-200 font-medium">
                                {project.year}
                            </p>
                        </div>
                        <div>
                            <p
                                class="text-gray-500 dark:text-gray-400 font-semibold text-xs tracking-wider uppercase mb-3"
                            >
                                Tech Stack
                            </p>
                            <div class="flex flex-wrap gap-2">
                                {
                                    project.stack.map((tech) => (
                                        <span class="bg-gray-100 dark:bg-white/10 border border-gray-200 dark:border-white/10 text-gray-600 dark:text-gray-300 text-xs px-3 py-1.5 rounded-lg font-medium">
                                            {tech}
                                        </span>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Main>

<script>
    // @ts-ignore
    import Plyr from "plyr";
    // @ts-ignore
    import "fslightbox";

    document.addEventListener("astro:page-load", () => {
        const playerElement = document.getElementById("player");
        if (playerElement) {
            new Plyr("#player", {
                controls: [
                    "play-large",
                    "play",
                    "progress",
                    "current-time",
                    "mute",
                    "volume",
                    "fullscreen",
                ],
                youtube: {
                    noCookie: false,
                    rel: 0,
                    showinfo: 0,
                    iv_load_policy: 3,
                    modestbranding: 1,
                },
            });
        }

        // Re-initialize lightbox links securely matching attributes
        // @ts-ignore
        if (typeof refreshFsLightbox !== "undefined") {
            // @ts-ignore
            refreshFsLightbox();
        }
    });
</script>
